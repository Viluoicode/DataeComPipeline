# Copy to .env on the server and fill real values. NEVER commit .env (it is gitignored).
#
#   cp .env.example .env && nano .env

# Public domain pointing (A record) at the VPS IP. Caddy gets HTTPS for it.
# Free option: a *.duckdns.org subdomain.
DOMAIN=ecom.example.com

# SQL Server SA password — MUST meet complexity: 8+ chars, upper + lower + digit + symbol.
SA_PASSWORD=Ch4nge_Me#Str0ng2026

# JWT signing secret — 32+ random chars. Production REFUSES to boot with a weak/dev secret.
# Generate one:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-32-plus-char-random-secret-value
