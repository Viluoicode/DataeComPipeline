# Caddy auto-provisions and renews a Let's Encrypt certificate for $DOMAIN.
# It reverse-proxies everything to the frontend container, whose nginx already
# serves the SPA and proxies /api, /hub (WebSocket), /hangfire, /scalar, /health
# to the API. WebSocket upgrades pass through Caddy transparently.

{$DOMAIN} {
	encode gzip zstd
	reverse_proxy frontend:80
}
