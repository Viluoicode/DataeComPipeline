# ──────────────────────────────────────────────────────────────
# Copy this file to ".env" and adjust if needed:   cp .env.example .env
# The .env file is gitignored — your credentials never get committed.
# ──────────────────────────────────────────────────────────────

# --- Source: SQL Server OLTP (ECommerPipeline_Oltp) ---
# Defaults match the Docker stack (docker compose up -d) from the root project.
OLTP_HOST=localhost
OLTP_PORT=1433
OLTP_DB=ECommerPipeline_Oltp
OLTP_USER=sa
OLTP_PASSWORD=YourStrong@Passw0rd
# ODBC driver name as installed on your machine (18 is current; 17 also works)
OLTP_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# --- Destination: local DuckDB warehouse file ---
DUCKDB_PATH=warehouse.duckdb
